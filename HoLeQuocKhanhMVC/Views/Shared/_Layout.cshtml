@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    var role = HttpContextAccessor.HttpContext?.Session.GetString("Role");
    var username = HttpContextAccessor.HttpContext?.Session.GetString("Username");
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FUNewsManagementSystem</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div id="antiforgery-token-container" style="display:none;">
        @Html.AntiForgeryToken()
    </div>

    <header>
        <nav class="navbar navbar-expand-lg navbar-custom box-shadow mb-4">
            <div class="container-fluid d-flex align-items-center justify-content-between">
                <!-- Brand logo -->
                <a class="navbar-brand navbar-brand-custom" href="@Url.Action("Index", "News")">
                    <i class="bi bi-newspaper"></i><span>FU News</span>
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <i class="bi bi-list fs-3 text-dark"></i>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <!-- Nav links cluster -->
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 align-items-center gap-1">
                        @if (role == null)
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom @(currentController == "News" && currentAction == "Index" ? "active" : "")" href="@Url.Action("Index", "News")">Home</a>
                            </li>
                        }
                        else if (role == "Lecturer")
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom @(currentController == "News" && currentAction == "Index" ? "active" : "")" href="@Url.Action("Index", "News")">Home</a>
                            </li>
                        }
                        else if (role == "Staff")
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom @(currentController == "News" && currentAction == "Index" ? "active" : "")" href="@Url.Action("Index", "News")">Articles</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom @(currentController == "News" && currentAction == "History" ? "active" : "")" href="@Url.Action("History", "News")">History</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom @(currentController == "Category" ? "active" : "")" href="@Url.Action("Index", "Category")">Categories</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom @(currentController == "Account" && currentAction == "Profile" ? "active" : "")" href="@Url.Action("Profile", "Account")">Profile</a>
                            </li>
                        }
                        else if (role == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom @(currentController == "Admin" && currentAction == "Accounts" ? "active" : "")" href="@Url.Action("Accounts", "Admin")">Accounts</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom @(currentController == "Admin" && currentAction == "Report" ? "active" : "")" href="@Url.Action("Report", "Admin")">Statistics</a>
                            </li>
                        }
                    </ul>

                    <!-- Right Cluster -->
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        @if (role != null)
                        {
                            <span class="text-dark fw-bold me-2" style="font-size: 0.95rem;">
                                <i class="bi bi-person-fill"></i> @username 
                                <span class="badge-custom @(role == "Admin" ? "badge-custom-inactive" : "badge-custom-role-staff") ms-1" style="font-size: 0.75rem;">
                                    @role
                                </span>
                            </span>
                            <a href="@Url.Action("Logout", "Account")" class="btn btn-premium btn-premium-danger" style="padding: 0.4rem 1.2rem; font-size: 0.9rem;">
                                <i class="bi bi-box-arrow-right"></i> Logout
                            </a>
                        }
                        else
                        {
                            <a href="@Url.Action("Login", "Account")" class="btn btn-premium btn-premium-primary" style="padding: 0.4rem 1.2rem; font-size: 0.9rem;">
                                <i class="bi bi-box-arrow-in-right"></i> Member Sign In
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mb-5">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="text-muted">
        <div class="container">
            &copy; 2026 - FUNewsManagementSystem - HoLeQuocKhanhMVC
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
