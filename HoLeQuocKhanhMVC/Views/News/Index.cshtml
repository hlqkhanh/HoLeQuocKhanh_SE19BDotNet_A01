@model IEnumerable<BusinessObjects.NewsArticle>
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    ViewData["Title"] = "News Portal";
    var role = HttpContextAccessor.HttpContext?.Session.GetString("Role");
}

<div class="container mt-2">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h1 class="fw-bold m-0"><i class="bi bi-newspaper text-primary"></i> News Articles</h1>
            <p class="text-muted m-0">Stay informed with the latest updates from FUNews</p>
        </div>
        @if (role == "Staff")
        {
            <button class="btn btn-premium btn-premium-primary" onclick="openNewsModal('')">
                <i class="bi bi-plus-lg"></i> Create News Article
            </button>
        }
    </div>

    <!-- Filters Section -->
    <div class="card-premium p-4 mb-4">
        <form method="get" action="@Url.Action("Index", "News")" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label for="searchString" class="form-label font-title fw-semibold">Search news...</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" id="searchString" name="searchString" value="@ViewBag.CurrentSearch" class="form-control form-control-custom border-start-0 ps-0" placeholder="Title, headline, tags..." />
                </div>
            </div>
            <div class="col-md-4">
                <label for="categoryFilter" class="form-label font-title fw-semibold">Category Filter</label>
                <select id="categoryFilter" name="categoryFilter" class="form-select form-control-custom">
                    <option value="">All Categories</option>
                    @foreach (var cat in ViewBag.Categories as IEnumerable<BusinessObjects.Category>)
                    {
                        <!option value="@cat.CategoryId" @(ViewBag.CurrentCategory == cat.CategoryId ? "selected" : "")>@cat.CategoryName</!option>
                    }
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-premium btn-premium-primary flex-grow-1">
                    Apply Filters
                </button>
                <a href="@Url.Action("Index", "News")" class="btn btn-premium btn-premium-secondary">
                    Clear
                </a>
            </div>
        </form>
    </div>

    <!-- News Grid -->
    @if (!Model.Any())
    {
        <div class="card-premium p-5 text-center my-4">
            <i class="bi bi-folder-x display-1 text-muted"></i>
            <h3 class="mt-3 font-title fw-semibold">No News Articles Found</h3>
            <p class="text-muted">Try adjusting your keywords or category filters.</p>
        </div>
    }
    else
    {
        <div class="news-grid mb-5">
            @foreach (var item in Model)
            {
                <div class="card-premium news-card p-4 d-flex flex-column justify-content-between">
                    <div>
                        <div class="news-meta">
                            <span class="badge-custom badge-custom-role-lecturer font-title">
                                <i class="bi bi-tag-fill"></i> @(item.Category?.CategoryName ?? "General")
                            </span>
                            <span>
                                <i class="bi bi-calendar3"></i> @(item.CreatedDate?.ToString("dd MMM yyyy") ?? "N/A")
                            </span>
                        </div>

                        @if (!string.IsNullOrEmpty(item.NewsImage))
                        {
                            <div class="news-image-wrapper mb-3" style="overflow: hidden; border-radius: var(--radius-md); height: 180px; width: 100%;">
                                <img src="@item.NewsImage" alt="@item.NewsTitle" style="width: 100%; height: 100%; object-fit: cover;" />
                            </div>
                        }

                        <h4 class="font-title fw-bold text-dark mb-2">@item.NewsTitle</h4>
                        <h6 class="text-primary fw-semibold mb-3">@item.Headline</h6>
                        <p class="text-muted mb-3" style="font-size: 0.95rem; display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis; height: 6.4em;">
                            @item.NewsContent
                        </p>
                    </div>

                    <div>
                        <div class="border-top pt-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <div class="text-muted" style="font-size: 0.8rem;">
                                <span>By: <strong>@(item.CreatedBy?.AccountName ?? "System")</strong></span>
                                @if (role == "Staff")
                                {
                                    <br />
                                    <span>Status: </span>
                                    <span class="badge-custom @(item.NewsStatus == true ? "badge-custom-active" : "badge-custom-inactive")" style="font-size: 0.65rem; padding: 0.1rem 0.4rem;">
                                        @(item.NewsStatus == true ? "Active" : "Inactive")
                                    </span>
                                }
                            </div>

                            <div class="d-flex gap-1">
                                <a href="@Url.Action("Details", "News", new { id = item.NewsArticleId })" class="btn btn-premium btn-premium-secondary btn-sm px-2 py-1" title="View Details">
                                    <i class="bi bi-eye text-primary"></i> View Details
                                </a>
                                @if (role == "Staff")
                                {
                                    <button class="btn btn-premium btn-premium-secondary btn-sm px-2 py-1" onclick="openNewsModal('@item.NewsArticleId')" title="Edit">
                                        <i class="bi bi-pencil-square text-primary"></i> Edit
                                    </button>
                                    <button class="btn btn-premium btn-premium-secondary btn-sm px-2 py-1" onclick="confirmDeleteNews('@item.NewsArticleId')" title="Delete">
                                        <i class="bi bi-trash text-danger"></i> Delete
                                    </button>
                                }
                            </div>
                        </div>

                        @if (item.Tags.Any())
                        {
                            <div class="news-tags-list">
                                @foreach (var tag in item.Tags)
                                {
                                    <span class="news-tag-badge">#@tag.TagName</span>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Modal Placeholder -->
<div class="modal fade" id="newsModal" tabindex="-1" aria-labelledby="newsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content modal-content-custom" id="newsModalContent">
            <!-- Content loaded via AJAX -->
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openNewsModal(id) {
            $.get('@Url.Action("GetNewsModal", "News")?id=' + id, function (data) {
                $('#newsModalContent').html(data);
                $('#newsModal').modal('show');
            }).fail(function () {
                alert("Failed to load news form.");
            });
        }

        function confirmDeleteNews(id) {
            if (confirm("Are you sure you want to delete this news article? This action cannot be undone.")) {
                $.ajax({
                    url: '@Url.Action("Delete", "News")',
                    type: 'POST',
                    data: {
                        id: id,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (result) {
                        if (result.success) {
                            location.reload();
                        } else {
                            alert(result.message || "Failed to delete article.");
                        }
                    },
                    error: function () {
                        alert("Error occurred during request.");
                    }
                });
            }
        }
    </script>
}
