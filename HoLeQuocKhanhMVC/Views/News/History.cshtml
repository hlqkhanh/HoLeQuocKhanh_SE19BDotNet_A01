@model IEnumerable<BusinessObjects.NewsArticle>

@{
    ViewData["Title"] = "My Creation History";
}

<div class="container mt-2">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h1 class="fw-bold m-0"><i class="bi bi-clock-history text-primary"></i> My Creation History</h1>
            <p class="text-muted m-0">Review and manage articles you have written for FU News</p>
        </div>
        <button class="btn btn-premium btn-premium-primary" onclick="openNewsModal('')">
            <i class="bi bi-plus-lg"></i> Create News Article
        </button>
    </div>

    @if (!Model.Any())
    {
        <div class="card-premium p-5 text-center my-4">
            <i class="bi bi-calendar-x display-1 text-muted"></i>
            <h3 class="mt-3 font-title fw-semibold">No Articles Created Yet</h3>
            <p class="text-muted">You haven't written any news articles. Click the button above to publish your first one!</p>
        </div>
    }
    else
    {
        <div class="card-premium p-0 mb-5 overflow-hidden">
            <div class="p-4 bg-light border-bottom">
                <h5 class="m-0 font-title fw-bold">Total Written: @Model.Count() @(Model.Count() == 1 ? "Article" : "Articles")</h5>
            </div>
            <div class="table-responsive p-4">
                <table class="table table-premium">
                    <thead>
                        <tr>
                            <th>Article ID</th>
                            <th>Title</th>
                            <th>Category</th>
                            <th>Created Date</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-muted">@item.NewsArticleId</td>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        @if (!string.IsNullOrEmpty(item.NewsImage))
                                        {
                                            <img src="@item.NewsImage" alt="" style="width: 50px; height: 50px; object-fit: cover; border-radius: var(--radius-sm);" />
                                        }
                                        <div>
                                            <div class="fw-semibold text-dark">@item.NewsTitle</div>
                                            <small class="text-muted">@item.Headline</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge-custom badge-custom-role-lecturer">
                                        @(item.Category?.CategoryName ?? "General")
                                    </span>
                                </td>
                                <td>
                                    @(item.CreatedDate?.ToString("dd MMM yyyy HH:mm") ?? "N/A")
                                </td>
                                <td>
                                    <span class="badge-custom @(item.NewsStatus == true ? "badge-custom-active" : "badge-custom-inactive")">
                                        @(item.NewsStatus == true ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-2">
                                        <button class="btn btn-premium btn-premium-secondary btn-sm" onclick="openNewsModal('@item.NewsArticleId')">
                                            <i class="bi bi-pencil-square text-primary"></i> Edit
                                        </button>
                                        <button class="btn btn-premium btn-premium-secondary btn-sm" onclick="confirmDeleteNews('@item.NewsArticleId')">
                                            <i class="bi bi-trash text-danger"></i> Delete
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<!-- Modal Placeholder -->
<div class="modal fade" id="newsModal" tabindex="-1" aria-labelledby="newsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content modal-content-custom" id="newsModalContent">
            <!-- Content loaded via AJAX -->
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openNewsModal(id) {
            $.get('@Url.Action("GetNewsModal", "News")?id=' + id, function (data) {
                $('#newsModalContent').html(data);
                $('#newsModal').modal('show');
            }).fail(function () {
                alert("Failed to load news form.");
            });
        }

        function confirmDeleteNews(id) {
            if (confirm("Are you sure you want to delete this news article? This action cannot be undone.")) {
                $.ajax({
                    url: '@Url.Action("Delete", "News")',
                    type: 'POST',
                    data: {
                        id: id,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (result) {
                        if (result.success) {
                            location.reload();
                        } else {
                            alert(result.message || "Failed to delete article.");
                        }
                    },
                    error: function () {
                        alert("Error occurred during request.");
                    }
                });
            }
        }
    </script>
}
