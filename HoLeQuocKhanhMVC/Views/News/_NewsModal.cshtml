@model BusinessObjects.NewsArticle

<div class="modal-header modal-header-custom">
    <h5 class="modal-title font-title fw-bold" id="newsModalLabel">
        @(string.IsNullOrEmpty(Model.NewsArticleId) ? "Create News Article" : "Edit News Article")
    </h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<form id="newsForm" asp-action="SaveNews" asp-controller="News" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="NewsArticleId" />

    <div class="modal-body p-4 text-start">
        <div id="modalError" class="alert alert-danger d-none"></div>

        <div class="text-danger" asp-validation-summary="ModelOnly"></div>

        <div class="row">
            <div class="col-md-8">
                <div class="form-group">
                    <label asp-for="NewsTitle" class="form-label font-title fw-semibold">News Title</label>
                    <input asp-for="NewsTitle" class="form-control form-control-custom" placeholder="Enter article title" required />
                    <span asp-validation-for="NewsTitle" class="text-danger" style="font-size: 0.85rem;"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group">
                    <label asp-for="CategoryId" class="form-label font-title fw-semibold">Category</label>
                    <select asp-for="CategoryId" class="form-select form-control-custom" required>
                        <option value="">-- Select Category --</option>
                        @foreach (var cat in ViewBag.Categories as IEnumerable<BusinessObjects.Category>)
                        {
                            <option value="@cat.CategoryId">@cat.CategoryName</option>
                        }
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger" style="font-size: 0.85rem;"></span>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-8">
                <div class="form-group">
                    <label asp-for="Headline" class="form-label font-title fw-semibold">Headline</label>
                    <input asp-for="Headline" class="form-control form-control-custom" placeholder="Short catchphrase or summary" required />
                    <span asp-validation-for="Headline" class="text-danger" style="font-size: 0.85rem;"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group">
                    <label asp-for="NewsSource" class="form-label font-title fw-semibold">News Source</label>
                    <input asp-for="NewsSource" class="form-control form-control-custom" placeholder="Reuters, BBC, Intern..." />
                    <span asp-validation-for="NewsSource" class="text-danger" style="font-size: 0.85rem;"></span>
                </div>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="NewsImage" class="form-label font-title fw-semibold">Image URL (Optional)</label>
            <input asp-for="NewsImage" id="NewsImageInput" class="form-control form-control-custom" placeholder="e.g., https://images.unsplash.com/... or local path" />
            <span asp-validation-for="NewsImage" class="text-danger" style="font-size: 0.85rem;"></span>
            <div id="imagePreviewContainer" class="mt-2 d-none" style="position: relative; max-width: 200px; max-height: 120px; overflow: hidden; border-radius: var(--radius-sm); border: 1px solid var(--slate-200);">
                <img id="imagePreview" src="" alt="Image Preview" style="width: 100%; height: auto; max-height: 120px; object-fit: cover;" />
            </div>
        </div>

        <div class="form-group">
            <label asp-for="NewsContent" class="form-label font-title fw-semibold">Article Content</label>
            <textarea asp-for="NewsContent" rows="5" class="form-control form-control-custom" placeholder="Write news content here..." required></textarea>
            <span asp-validation-for="NewsContent" class="text-danger" style="font-size: 0.85rem;"></span>
        </div>

        <!-- Tags List Multi-Select (Pills style) -->
        <div class="form-group">
            <label class="form-label font-title fw-semibold">Tags / Labels</label>
            <div class="tag-checkbox-container">
                @foreach (var tag in ViewBag.Tags as IEnumerable<BusinessObjects.Tag>)
                {
                    var isChecked = Model.Tags.Any(t => t.TagId == tag.TagId);
                    <label class="tag-checkbox-item @(isChecked ? "checked" : "")" id="label-tag-@tag.TagId">
                        <input type="checkbox" name="selectedTags" value="@tag.TagId" @(isChecked ? "checked" : "") onchange="toggleTagClass(this, @tag.TagId)" />
                        @tag.TagName
                    </label>
                }
            </div>
        </div>

        <div class="form-check form-switch mt-3">
            <input class="form-check-input" type="checkbox" id="NewsStatus" name="NewsStatus" value="true" @(Model.NewsStatus == true ? "checked" : "") />
            <label class="form-check-label font-title fw-semibold text-dark" for="NewsStatus">Publish immediately (Active)</label>
            <input type="hidden" name="NewsStatus" value="false" /> <!-- fallback for unticked checkbox -->
        </div>
    </div>

    <div class="modal-footer bg-light">
        <button type="button" class="btn btn-premium btn-premium-secondary" data-bs-dismiss="modal">Close</button>
        <button type="submit" class="btn btn-premium btn-premium-primary">
            <i class="bi bi-check-lg"></i> Save Article
        </button>
    </div>
</form>

<script>
    function toggleTagClass(checkbox, tagId) {
        var label = document.getElementById('label-tag-' + tagId);
        if (checkbox.checked) {
            label.classList.add('checked');
        } else {
            label.classList.remove('checked');
        }
    }

    function updateImagePreview() {
        var url = $('#NewsImageInput').val();
        if (url && url.trim() !== '') {
            $('#imagePreview').attr('src', url);
            $('#imagePreviewContainer').removeClass('d-none');
        } else {
            $('#imagePreviewContainer').addClass('d-none');
            $('#imagePreview').attr('src', '');
        }
    }

    $(document).ready(function () {
        updateImagePreview();

        $('#NewsImageInput').on('input', function() {
            updateImagePreview();
        });

        // Handle AJAC Form Submit inside modal
        $('#newsForm').on('submit', function (e) {
            e.preventDefault();
            var form = $(this);
            
            $.ajax({
                url: form.attr('action'),
                type: form.attr('method'),
                data: form.serialize(),
                success: function (response) {
                    if (response.success) {
                        $('#newsModal').modal('hide');
                        location.reload();
                    } else if (response.message) {
                        $('#modalError').text(response.message).removeClass('d-none');
                    } else {
                        // If it returns partial view HTML (meaning validation errors)
                        $('#newsModalContent').html(response);
                    }
                },
                error: function () {
                    $('#modalError').text("An error occurred. Please try again.").removeClass('d-none');
                }
            });
        });
    });
</script>
