@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - FUNewsManagementSystem</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="login-container">
        <div class="login-card">
            <div class="login-header-logo">
                FU News Portal
            </div>
            <p class="text-muted mb-4">News Management System portal login</p>

            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()
                
                <div class="text-danger mb-3" style="font-size: 0.9rem;">
                    @Html.ValidationSummary(true)
                </div>

                <div class="form-group text-start">
                    <label for="email" class="form-label font-title fw-semibold text-dark">Email Address</label>
                    <input type="email" id="email" name="email" class="form-control form-control-custom" placeholder="name@funewsmanagementsystem.org" required />
                </div>

                <div class="form-group text-start mb-4">
                    <label for="password" class="form-label font-title fw-semibold text-dark">Password</label>
                    <input type="password" id="password" name="password" class="form-control form-control-custom" placeholder="••••••••" required />
                </div>

                <button type="submit" class="btn btn-premium btn-premium-primary w-100 mb-3">
                    Sign In
                </button>
            </form>

            <div class="divider d-flex align-items-center my-3">
                <hr class="flex-grow-1 text-muted" />
                <span class="mx-3 text-muted" style="font-size: 0.85rem;">or</span>
                <hr class="flex-grow-1 text-muted" />
            </div>

            <a href="@Url.Action("Index", "News")" class="btn btn-premium btn-premium-secondary w-100">
                Browse as Guest
            </a>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
