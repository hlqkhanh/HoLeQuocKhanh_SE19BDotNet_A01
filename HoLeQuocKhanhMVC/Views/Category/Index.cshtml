@model IEnumerable<BusinessObjects.Category>

@{
    ViewData["Title"] = "Manage Categories";
}

<div class="container mt-2">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h1 class="fw-bold m-0"><i class="bi bi-tags text-primary"></i> Categories</h1>
            <p class="text-muted m-0">Organize and manage category labels for news articles</p>
        </div>
        <button class="btn btn-premium btn-premium-primary" onclick="openCategoryModal(0)">
            <i class="bi bi-plus-lg"></i> Create Category
        </button>
    </div>

    <!-- Filters Section -->
    <div class="card-premium p-4 mb-4">
        <form method="get" action="@Url.Action("Index", "Category")" class="row g-3 align-items-end">
            <div class="col-md-9">
                <label for="searchString" class="form-label font-title fw-semibold">Search categories...</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" id="searchString" name="searchString" value="@ViewBag.CurrentSearch" class="form-control form-control-custom border-start-0 ps-0" placeholder="Category name or description..." />
                </div>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-premium btn-premium-primary flex-grow-1">
                    Search
                </button>
                <a href="@Url.Action("Index", "Category")" class="btn btn-premium btn-premium-secondary">
                    Clear
                </a>
            </div>
        </form>
    </div>

    @if (!Model.Any())
    {
        <div class="card-premium p-5 text-center my-4">
            <i class="bi bi-tag-fill display-1 text-muted"></i>
            <h3 class="mt-3 font-title fw-semibold">No Categories Found</h3>
            <p class="text-muted">Try a different keyword.</p>
        </div>
    }
    else
    {
        <div class="card-premium p-0 mb-5 overflow-hidden">
            <div class="table-responsive p-4">
                <table class="table table-premium">
                    <thead>
                        <tr>
                            <th>Category ID</th>
                            <th>Category Name</th>
                            <th>Description</th>
                            <th>Parent Category</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-muted">#@item.CategoryId</td>
                                <td class="fw-semibold text-dark">@item.CategoryName</td>
                                <td>@item.CategoryDesciption</td>
                                <td>
                                    @if (item.ParentCategory != null)
                                    {
                                        <span class="badge-custom badge-custom-role-staff">
                                            @item.ParentCategory.CategoryName
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted" style="font-size: 0.85rem;">None (Root)</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge-custom @(item.IsActive == true ? "badge-custom-active" : "badge-custom-inactive")">
                                        @(item.IsActive == true ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-2">
                                        <button class="btn btn-premium btn-premium-secondary btn-sm" onclick="openCategoryModal(@item.CategoryId)">
                                            <i class="bi bi-pencil-square text-primary"></i> Edit
                                        </button>
                                        <button class="btn btn-premium btn-premium-secondary btn-sm" onclick="confirmDeleteCategory(@item.CategoryId)">
                                            <i class="bi bi-trash text-danger"></i> Delete
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<!-- Modal Placeholder -->
<div class="modal fade" id="categoryModal" tabindex="-1" aria-labelledby="categoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-content-custom" id="categoryModalContent">
            <!-- Content loaded via AJAX -->
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openCategoryModal(id) {
            $.get('@Url.Action("GetCategoryModal", "Category")?id=' + id, function (data) {
                $('#categoryModalContent').html(data);
                $('#categoryModal').modal('show');
            }).fail(function () {
                alert("Failed to load category form.");
            });
        }

        function confirmDeleteCategory(id) {
            if (confirm("Are you sure you want to delete this category? This operation is permanent.")) {
                $.ajax({
                    url: '@Url.Action("Delete", "Category")',
                    type: 'POST',
                    data: {
                        id: id,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (result) {
                        if (result.success) {
                            location.reload();
                        } else {
                            // If references exist, showing custom validation alerts
                            alert(result.message || "Failed to delete category.");
                        }
                    },
                    error: function () {
                        alert("Error occurred during request.");
                    }
                });
            }
        }
    </script>
}
