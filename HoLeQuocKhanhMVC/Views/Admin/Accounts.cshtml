@model IEnumerable<BusinessObjects.SystemAccount>

@{
    ViewData["Title"] = "Manage Accounts";
}

<div class="container mt-2">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h1 class="fw-bold m-0"><i class="bi bi-people text-primary"></i> System Accounts</h1>
            <p class="text-muted m-0">Admin dashboard to manage staff and lecturer credentials</p>
        </div>
        <button class="btn btn-premium btn-premium-primary" onclick="openAccountModal(null)">
            <i class="bi bi-person-plus"></i> Create New Account
        </button>
    </div>

    <!-- Filters Section -->
    <div class="card-premium p-4 mb-4">
        <form method="get" action="@Url.Action("Accounts", "Admin")" class="row g-3 align-items-end">
            <div class="col-md-9">
                <label for="searchString" class="form-label font-title fw-semibold">Search accounts...</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" id="searchString" name="searchString" value="@ViewBag.CurrentSearch" class="form-control form-control-custom border-start-0 ps-0" placeholder="Name or email address..." />
                </div>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-premium btn-premium-primary flex-grow-1">
                    Search
                </button>
                <a href="@Url.Action("Accounts", "Admin")" class="btn btn-premium btn-premium-secondary">
                    Clear
                </a>
            </div>
        </form>
    </div>

    @if (!Model.Any())
    {
        <div class="card-premium p-5 text-center my-4">
            <i class="bi bi-person-x display-1 text-muted"></i>
            <h3 class="mt-3 font-title fw-semibold">No Accounts Found</h3>
            <p class="text-muted">Try a different name or email search.</p>
        </div>
    }
    else
    {
        <div class="card-premium p-0 mb-5 overflow-hidden">
            <div class="table-responsive p-4">
                <table class="table table-premium">
                    <thead>
                        <tr>
                            <th>Account ID</th>
                            <th>Full Name</th>
                            <th>Email Address</th>
                            <th>Role</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-muted">#@item.AccountId</td>
                                <td class="fw-semibold text-dark">@item.AccountName</td>
                                <td>@item.AccountEmail</td>
                                <td>
                                    @if (item.AccountRole == 1)
                                    {
                                        <span class="badge-custom badge-custom-role-staff">
                                            <i class="bi bi-shield-lock-fill"></i> Staff
                                        </span>
                                    }
                                    else if (item.AccountRole == 2)
                                    {
                                        <span class="badge-custom badge-custom-role-lecturer">
                                            <i class="bi bi-book-half"></i> Lecturer
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge-custom badge-custom-inactive">Unknown</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-2">
                                        <button class="btn btn-premium btn-premium-secondary btn-sm" onclick="openAccountModal(@item.AccountId)">
                                            <i class="bi bi-pencil-square text-primary"></i> Edit
                                        </button>
                                        <button class="btn btn-premium btn-premium-secondary btn-sm" onclick="confirmDeleteAccount(@item.AccountId)">
                                            <i class="bi bi-trash text-danger"></i> Delete
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<!-- Modal Placeholder -->
<div class="modal fade" id="accountModal" tabindex="-1" aria-labelledby="accountModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-content-custom" id="accountModalContent">
            <!-- Content loaded via AJAX -->
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openAccountModal(id) {
            var url = '@Url.Action("GetAccountModal", "Admin")';
            if (id !== null) {
                url += '?id=' + id;
            }
            $.get(url, function (data) {
                $('#accountModalContent').html(data);
                $('#accountModal').modal('show');
            }).fail(function () {
                alert("Failed to load account form.");
            });
        }

        function confirmDeleteAccount(id) {
            if (confirm("Are you sure you want to delete this account? This action will permanently remove it from the system.")) {
                $.ajax({
                    url: '@Url.Action("Delete", "Admin")',
                    type: 'POST',
                    data: {
                        id: id,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (result) {
                        if (result.success) {
                            location.reload();
                        } else {
                            alert(result.message || "Failed to delete account.");
                        }
                    },
                    error: function () {
                        alert("Error occurred during request.");
                    }
                });
            }
        }
    </script>
}
